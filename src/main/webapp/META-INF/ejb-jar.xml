<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ejb-jar PUBLIC 
    "-//Sun Microsystems, Inc.//DTD Enterprise JavaBeans 2.0//EN" 
    "http://java.sun.com/dtd/ejb-jar_2_0.dtd">

<ejb-jar>
    <display-name>Banking EJB Module</display-name>
    <description>EJB 2.x components for Banking Application</description>

    <enterprise-beans>
        
        <!-- Banking Facade Session Bean -->
        <session>
            <display-name>BankingFacade</display-name>
            <ejb-name>BankingFacadeBean</ejb-name>
            <home>com.banking.ejb.BankingFacadeHome</home>
            <remote>com.banking.ejb.BankingFacade</remote>
            <local-home>com.banking.ejb.BankingFacadeLocalHome</local-home>
            <local>com.banking.ejb.BankingFacadeLocal</local>
            <ejb-class>com.banking.ejb.BankingFacadeBean</ejb-class>
            <session-type>Stateless</session-type>
            <transaction-type>Container</transaction-type>
            
            <ejb-local-ref>
                <ejb-ref-name>ejb/AccountEntity</ejb-ref-name>
                <ejb-ref-type>Entity</ejb-ref-type>
                <local-home>com.banking.ejb.AccountLocalHome</local-home>
                <local>com.banking.ejb.AccountLocal</local>
                <ejb-link>AccountBean</ejb-link>
            </ejb-local-ref>
            
            <ejb-local-ref>
                <ejb-ref-name>ejb/CustomerEntity</ejb-ref-name>
                <ejb-ref-type>Entity</ejb-ref-type>
                <local-home>com.banking.ejb.CustomerLocalHome</local-home>
                <local>com.banking.ejb.CustomerLocal</local>
                <ejb-link>CustomerBean</ejb-link>
            </ejb-local-ref>
            
            <resource-ref>
                <res-ref-name>jdbc/BankingDB</res-ref-name>
                <res-type>javax.sql.DataSource</res-type>
                <res-auth>Container</res-auth>
            </resource-ref>
        </session>

        <!-- Account Entity Bean (CMP) -->
        <entity>
            <display-name>Account</display-name>
            <ejb-name>AccountBean</ejb-name>
            <local-home>com.banking.ejb.AccountLocalHome</local-home>
            <local>com.banking.ejb.AccountLocal</local>
            <ejb-class>com.banking.ejb.AccountBean</ejb-class>
            <persistence-type>Container</persistence-type>
            <prim-key-class>java.lang.Long</prim-key-class>
            <reentrant>False</reentrant>
            
            <!-- CMP Fields -->
            <cmp-field>
                <field-name>accountId</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>accountNumber</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>accountType</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>balance</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>customerId</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>createdDate</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>status</field-name>
            </cmp-field>
            
            <primkey-field>accountId</primkey-field>
            
            <!-- Queries -->
            <query>
                <query-method>
                    <method-name>findByAccountNumber</method-name>
                    <method-params>
                        <method-param>java.lang.String</method-param>
                    </method-params>
                </query-method>
                <ejb-ql>
                    SELECT OBJECT(a) FROM Account a WHERE a.accountNumber = ?1
                </ejb-ql>
            </query>
            
            <query>
                <query-method>
                    <method-name>findByCustomerId</method-name>
                    <method-params>
                        <method-param>java.lang.Long</method-param>
                    </method-params>
                </query-method>
                <ejb-ql>
                    SELECT OBJECT(a) FROM Account a WHERE a.customerId = ?1
                </ejb-ql>
            </query>
        </entity>

        <!-- Customer Entity Bean (CMP) -->
        <entity>
            <display-name>Customer</display-name>
            <ejb-name>CustomerBean</ejb-name>
            <local-home>com.banking.ejb.CustomerLocalHome</local-home>
            <local>com.banking.ejb.CustomerLocal</local>
            <ejb-class>com.banking.ejb.CustomerBean</ejb-class>
            <persistence-type>Container</persistence-type>
            <prim-key-class>java.lang.Long</prim-key-class>
            <reentrant>False</reentrant>
            
            <!-- CMP Fields -->
            <cmp-field>
                <field-name>customerId</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>firstName</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>lastName</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>email</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>phone</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>address</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>username</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>password</field-name>
            </cmp-field>
            <cmp-field>
                <field-name>createdDate</field-name>
            </cmp-field>
            
            <primkey-field>customerId</primkey-field>
            
            <!-- Queries -->
            <query>
                <query-method>
                    <method-name>findByUsername</method-name>
                    <method-params>
                        <method-param>java.lang.String</method-param>
                    </method-params>
                </query-method>
                <ejb-ql>
                    SELECT OBJECT(c) FROM Customer c WHERE c.username = ?1
                </ejb-ql>
            </query>
            
            <query>
                <query-method>
                    <method-name>findByEmail</method-name>
                    <method-params>
                        <method-param>java.lang.String</method-param>
                    </method-params>
                </query-method>
                <ejb-ql>
                    SELECT OBJECT(c) FROM Customer c WHERE c.email = ?1
                </ejb-ql>
            </query>
        </entity>

    </enterprise-beans>

    <!-- Assembly Descriptor -->
    <assembly-descriptor>
        
        <!-- Container Transactions -->
        <container-transaction>
            <method>
                <ejb-name>BankingFacadeBean</ejb-name>
                <method-name>*</method-name>
            </method>
            <trans-attribute>Required</trans-attribute>
        </container-transaction>
        
        <container-transaction>
            <method>
                <ejb-name>AccountBean</ejb-name>
                <method-name>*</method-name>
            </method>
            <trans-attribute>Required</trans-attribute>
        </container-transaction>
        
        <container-transaction>
            <method>
                <ejb-name>CustomerBean</ejb-name>
                <method-name>*</method-name>
            </method>
            <trans-attribute>Required</trans-attribute>
        </container-transaction>

    </assembly-descriptor>

</ejb-jar>

